{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix web/frontend",
  "buildCommand": "npm run build --prefix web/frontend",
  "outputDirectory": "web/frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": { "includeFiles": "web/backend/**" }
  }
}
